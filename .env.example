# Copy to `.env` and fill with your AdMob IDs (Expo embeds `EXPO_PUBLIC_*` at build time).
# https://developers.google.com/admob/android/test-ads

EXPO_PUBLIC_ADMOB_APP_ID_IOS=
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID=
EXPO_PUBLIC_ADMOB_TEST_DEVICE_IDS=
EXPO_PUBLIC_ADMOB_FORCE_TEST_IDS=0
